# ===========================================
# hiram.work — Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local

# Resend — Email service for the contact form
# Get your API key at: https://resend.com/api-keys
# Required for the contact form to work.
# The build will succeed without it, but POST /api/contact will return 500.
RESEND_API_KEY=

# Upstash Redis — Rate limiting (optional)
# Get credentials at: https://console.upstash.com
# If not set, the contact form works without rate limiting.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
